# Another S3 Manager - Environment Variables
#
# Quick start (local dev):
#   1. cp .env.example .env
#   2. Generate a JWT key and paste below:
#        python -c 'import secrets; print(secrets.token_urlsafe(32))'
#   3. docker compose up
#
# .env is gitignored.

# REQUIRED: JWT Secret Key. Generate with the command above.
JWT_SECRET_KEY=PASTE_GENERATED_KEY_HERE

# Optional: Server configuration (defaults shown)
# PORT=8080
# UVICORN_HOST=0.0.0.0
# LOG_LEVEL=info

# Optional: AWS region default (boto3 picks up ~/.aws/config too).
# AWS_REGION=us-east-1

# DATA_DIR controls where the SQLite database (another_s3_manager.db), the role
# config (config.json), and any legacy users.json/bans.json live.
# Local dev (uv run) — defaults to ./data under the repo root.
# Docker — overridden in docker-compose.yml to /app/data (bind-mounted to host).
DATA_DIR=./data

# Path to the role/bucket config file. Lives inside DATA_DIR by convention.
S3_FILE_MANAGER_CONFIG=./data/config.json

# Admin password (default: change_me_pls).
# Seeds the 'admin' user on first boot, and is RE-APPLIED on restart whenever you
# change it — as long as the admin password is still managed by the environment.
# The moment the password is changed in the web UI (or via the reset CLI below),
# the database becomes authoritative and this variable is ignored.
# Lost the admin password? Reset it from inside the container:
#   docker compose exec app python -m another_s3_manager.reset_admin_password
ADMIN_PASSWORD=change_me_pls

# ADMIN_PASSWORD_FORCE — one-shot override. Leave it UNSET unless you need it.
# Set it to 1/true/yes and the next start applies ADMIN_PASSWORD to the 'admin' user
# even if the password was set in the web UI or with the reset CLI — OVERWRITING the
# current admin password — and hands password management back to the environment.
# Use it to recover environment management (e.g. after upgrading a deployment whose
# admin password had already been changed).
# REMOVE IT once it has done its job: while it is set, every restart overrides any
# password set through the UI. Any value other than 1/true/yes means "off".
# ADMIN_PASSWORD_FORCE=1

# Optional: JWT token expiration time in minutes (default: 180 = 3 hours)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=180

# COOKIE_SECURE controls the Secure flag on the auth cookie.
# - In production (HTTPS): leave as true (default)
# - On localhost (HTTP): MUST set to false, or browser will silently drop the cookie
COOKIE_SECURE=false

# Optional: File management settings
DISABLE_DELETION=false
MAX_FILE_SIZE=104857600
ENABLE_LAZY_LOADING=true

# Presigned URL lifetimes (seconds). DEFAULT is granted when a link is copied
# without choosing one; MAX bounds per-link overrides (7-day SigV4 ceiling).
# PRESIGNED_URL_DEFAULT_TTL=3600
# PRESIGNED_URL_MAX_TTL=604800
