# Another S3 Manager - Environment Variables
# Copy this file to .env and fill in your values
# The .env file is ignored by git for security

# REQUIRED: JWT Secret Key for authentication tokens
# Generate one with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
JWT_SECRET_KEY=your-secret-key-here-change-in-production

# Optional: Server configuration
PORT=8080
UVICORN_HOST=0.0.0.0
LOG_LEVEL=info

# Optional: AWS configuration
AWS_REGION=us-east-1

# Optional: Application configuration
S3_FILE_MANAGER_CONFIG=config.json

# DATA_DIR controls where the SQLite database (another_s3_manager.db),
# legacy users.json/bans.json, and other runtime data live.
# In Docker compose this is bind-mounted (e.g. ./data on host) so the DB
# persists across container restarts.
DATA_DIR=

# Optional: Admin user password (default: change_me_pls)
ADMIN_PASSWORD=change_me_pls

# Optional: JWT token expiration time in minutes (default: 180 = 3 hours)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=180

# Optional: File management settings
ITEMS_PER_PAGE=200
DISABLE_DELETION=false
MAX_FILE_SIZE=104857600
ENABLE_LAZY_LOADING=true

# Optional: Rate limiting
# Disable rate limiting entirely (true | false). Default: enabled.
RATE_LIMIT_ENABLED=true
# When the app sits behind a reverse proxy (Cloudflare, nginx, etc.), set this to
# the header carrying the real client IP — otherwise all requests look like one
# client and share a single quota. Common values: X-Forwarded-For, CF-Connecting-IP.
# Leave unset for direct exposure (no proxy).
RATE_LIMIT_PROXY_HEADER=
