{
  "__note": "Canonical source of truth — edit this file by hand, never by exporting from the Grafana UI (export injects __inputs and concrete datasource UIDs and breaks portability). Portability comes from the ${DS} datasource variable used by every panel.",
  "title": "Another S3 Manager",
  "uid": "as3m-overview",
  "tags": ["another-s3-manager", "s3", "mcp", "self-hosted"],
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "",
  "templating": {
    "list": [
      {
        "name": "DS",
        "label": "Data source",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "job",
        "label": "Job",
        "type": "query",
        "datasource": "${DS}",
        "query": "label_values(as3m_app_info, job)",
        "refresh": 2,
        "sort": 1,
        "current": {},
        "hide": 0
      },
      {
        "name": "instance",
        "label": "Instance",
        "type": "query",
        "datasource": "${DS}",
        "query": "label_values(as3m_app_info{job=\"$job\"}, instance)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {},
        "hide": 0
      },
      {
        "name": "role",
        "label": "Role",
        "type": "query",
        "datasource": "${DS}",
        "query": "label_values(as3m_s3_objects_total, role)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {},
        "hide": 0
      },
      {
        "name": "bucket",
        "label": "Bucket",
        "type": "query",
        "datasource": "${DS}",
        "query": "label_values(as3m_s3_objects_total{role=~\"$role\"}, bucket)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {},
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Overview",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Version",
      "description": "The running app version (from the APP_VERSION / build tag). Watch it flip after a deploy.",
      "datasource": "${DS}",
      "transparent": true,
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "name",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS}",
          "expr": "as3m_app_info{job=\"$job\", instance=~\"$instance\"}",
          "legendFormat": "{{version}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Uptime",
      "description": "Time since the process started. A reset to near-zero means the app restarted. Linux only (process_* reads /proc).",
      "datasource": "${DS}",
      "transparent": true,
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "B",
          "datasource": "${DS}",
          "expr": "time() - process_start_time_seconds{job=\"$job\", instance=~\"$instance\"}"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "In-flight requests",
      "description": "Requests currently being served. Sustained growth means the app is falling behind — e.g. a long 'Load all' or a bulk delete.",
      "datasource": "${DS}",
      "transparent": true,
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "C",
          "datasource": "${DS}",
          "expr": "sum(as3m_http_requests_in_flight{job=\"$job\", instance=~\"$instance\"})"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request rate",
      "description": "HTTP requests served per second. Overall load; a drop to zero means traffic stopped or the scrape target is down.",
      "datasource": "${DS}",
      "transparent": true,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["min", "max", "mean", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "D",
          "datasource": "${DS}",
          "expr": "sum(rate(as3m_http_requests_total{job=\"$job\", instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "requests/s"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "5xx error rate",
      "description": "Fraction of requests answered with a 5xx. This is server-side failure; sustained non-zero needs a look at the logs.",
      "datasource": "${DS}",
      "transparent": true,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["min", "max", "mean", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "E",
          "datasource": "${DS}",
          "expr": "sum(rate(as3m_http_requests_total{job=\"$job\", instance=~\"$instance\", status_code=~\"5..\"}[$__rate_interval])) / sum(rate(as3m_http_requests_total{job=\"$job\", instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "5xx ratio"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Request latency p95",
      "description": "95th-percentile request duration. Summed over le first, so the quantile is correct across route templates.",
      "datasource": "${DS}",
      "transparent": true,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["min", "max", "mean", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "F",
          "datasource": "${DS}",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(as3m_http_request_duration_seconds_bucket{job=\"$job\", instance=~\"$instance\"}[$__rate_interval])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 8,
      "type": "row",
      "title": "Storage activity",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 15
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Objects added / deleted",
      "description": "Objects uploaded and deleted per second. Counts real objects: deleting a folder of 5,000 objects registers 5,000, not one API call.",
      "datasource": "${DS}",
      "transparent": true,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["min", "max", "mean", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "G",
          "datasource": "${DS}",
          "expr": "sum by (bucket, operation) (rate(as3m_s3_objects_total{job=\"$job\", instance=~\"$instance\", role=~\"$role\", bucket=~\"$bucket\"}[$__rate_interval]))",
          "legendFormat": "{{bucket}} · {{operation}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Throughput",
      "description": "Bytes uploaded and downloaded per second, broken out by bucket (server-side copies move no bytes through the app, so they don't appear here).",
      "datasource": "${DS}",
      "transparent": true,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["min", "max", "mean", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "H",
          "datasource": "${DS}",
          "expr": "sum by (bucket, direction) (rate(as3m_s3_bytes_total{job=\"$job\", instance=~\"$instance\", role=~\"$role\", bucket=~\"$bucket\"}[$__rate_interval]))",
          "legendFormat": "{{bucket}} · {{direction}}"
        }
      ]
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Objects processed (total)",
      "description": "Cumulative objects uploaded/deleted/copied since start (honors the Role/Bucket filters). Delete counts can slightly under-count on a credential-expiry retry — see docs.",
      "datasource": "${DS}",
      "transparent": true,
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "I",
          "datasource": "${DS}",
          "expr": "sum(as3m_s3_objects_total{job=\"$job\", instance=~\"$instance\", role=~\"$role\", bucket=~\"$bucket\"})",
          "legendFormat": "objects"
        }
      ]
    },
    {
      "id": 12,
      "type": "table",
      "title": "Top buckets by object activity",
      "description": "Busiest buckets by objects/sec right now. Useful for spotting which bucket a spike is coming from.",
      "datasource": "${DS}",
      "transparent": true,
      "gridPos": {
        "h": 8,
        "w": 18,
        "x": 6,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "refId": "J",
          "datasource": "${DS}",
          "expr": "topk(10, sum by (bucket) (rate(as3m_s3_objects_total{job=\"$job\", instance=~\"$instance\", role=~\"$role\", bucket=~\"$bucket\"}[$__rate_interval])))",
          "legendFormat": "{{bucket}}",
          "instant": true,
          "format": "table"
        }
      ]
    },
    {
      "id": 18,
      "type": "row",
      "title": "S3 health",
      "collapsed": true,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "panels": [
        {
          "id": 13,
          "type": "timeseries",
          "title": "Operations by type",
          "description": "S3 API calls per second by kind (list/get/put/delete/head). This counts calls, not objects.",
          "datasource": "${DS}",
          "transparent": true,
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 0,
            "y": 17
          },
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "min": 0,
              "custom": {
                "drawStyle": "line",
                "fillOpacity": 12,
                "showPoints": "never",
                "stacking": {
                  "mode": "none"
                }
              }
            },
            "overrides": []
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": ["min", "max", "mean", "lastNotNull"]
            },
            "tooltip": {
              "mode": "multi",
              "sort": "desc"
            }
          },
          "targets": [
            {
              "refId": "K",
              "datasource": "${DS}",
              "expr": "sum by (operation) (rate(as3m_s3_operations_total{job=\"$job\", instance=~\"$instance\", role=~\"$role\"}[$__rate_interval]))",
              "legendFormat": "{{operation}}"
            }
          ]
        },
        {
          "id": 14,
          "type": "timeseries",
          "title": "Errors by cause",
          "description": "Failed S3 calls per second by cause. `access_denied` usually means a role's IAM policy changed; `throttled` means S3 is rate-limiting you.",
          "datasource": "${DS}",
          "transparent": true,
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 12,
            "y": 17
          },
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "min": 0,
              "custom": {
                "drawStyle": "bars",
                "fillOpacity": 60,
                "showPoints": "never",
                "stacking": {
                  "mode": "none"
                }
              }
            },
            "overrides": []
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": ["min", "max", "mean", "lastNotNull", "sum"]
            },
            "tooltip": {
              "mode": "multi",
              "sort": "desc"
            }
          },
          "targets": [
            {
              "refId": "L",
              "datasource": "${DS}",
              "expr": "sum by (error_code) (increase(as3m_s3_operations_total{job=\"$job\", instance=~\"$instance\", role=~\"$role\", error_code!=\"none\"}[$__rate_interval]))",
              "legendFormat": "{{error_code}}"
            }
          ]
        },
        {
          "id": 15,
          "type": "timeseries",
          "title": "Operation latency p95",
          "description": "95th-percentile S3 operation duration by kind. A rising put/list p95 is often the first sign of a slow or throttling backend.",
          "datasource": "${DS}",
          "transparent": true,
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 0,
            "y": 25
          },
          "fieldConfig": {
            "defaults": {
              "unit": "s",
              "min": 0,
              "custom": {
                "drawStyle": "line",
                "fillOpacity": 12,
                "showPoints": "never",
                "stacking": {
                  "mode": "none"
                }
              }
            },
            "overrides": []
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": ["min", "max", "mean", "lastNotNull"]
            },
            "tooltip": {
              "mode": "multi",
              "sort": "desc"
            }
          },
          "targets": [
            {
              "refId": "M",
              "datasource": "${DS}",
              "expr": "histogram_quantile(0.95, sum by (le, operation) (rate(as3m_s3_operation_duration_seconds_bucket{job=\"$job\", instance=~\"$instance\"}[$__rate_interval])))",
              "legendFormat": "{{operation}}"
            }
          ]
        },
        {
          "id": 16,
          "type": "timeseries",
          "title": "Credential-expiry retries",
          "description": "Transparent retries after expired credentials, per second. A steady non-zero rate points at a too-short STS session TTL.",
          "datasource": "${DS}",
          "transparent": true,
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 12,
            "y": 25
          },
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "min": 0,
              "custom": {
                "drawStyle": "bars",
                "fillOpacity": 60,
                "showPoints": "never",
                "stacking": {
                  "mode": "none"
                }
              }
            },
            "overrides": []
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": ["min", "max", "mean", "lastNotNull", "sum"]
            },
            "tooltip": {
              "mode": "multi",
              "sort": "desc"
            }
          },
          "targets": [
            {
              "refId": "N",
              "datasource": "${DS}",
              "expr": "sum by (reason) (increase(as3m_s3_retries_total{job=\"$job\", instance=~\"$instance\"}[$__rate_interval]))",
              "legendFormat": "{{reason}}"
            }
          ]
        },
        {
          "id": 17,
          "type": "timeseries",
          "title": "STS assume-role & refresh failures",
          "description": "Failed AssumeRole and credential-refresh calls per second. Silent before this dashboard existed; a spike here explains sudden AccessDenied errors.",
          "datasource": "${DS}",
          "transparent": true,
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 0,
            "y": 33
          },
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "min": 0,
              "custom": {
                "drawStyle": "bars",
                "fillOpacity": 60,
                "showPoints": "never",
                "stacking": {
                  "mode": "none"
                }
              }
            },
            "overrides": []
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": ["min", "max", "mean", "lastNotNull", "sum"]
            },
            "tooltip": {
              "mode": "multi",
              "sort": "desc"
            }
          },
          "targets": [
            {
              "refId": "O",
              "datasource": "${DS}",
              "expr": "sum(increase(as3m_sts_assume_role_total{job=\"$job\", instance=~\"$instance\", role=~\"$role\", result=\"error\"}[$__rate_interval]))",
              "legendFormat": "assume-role errors"
            },
            {
              "refId": "P",
              "datasource": "${DS}",
              "expr": "sum(increase(as3m_credentials_refreshed_total{job=\"$job\", instance=~\"$instance\", role=~\"$role\", result=\"error\"}[$__rate_interval]))",
              "legendFormat": "refresh errors"
            }
          ]
        }
      ]
    },
    {
      "id": 24,
      "type": "row",
      "title": "Auth & security",
      "collapsed": true,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 33
      },
      "panels": [
        {
          "id": 19,
          "type": "timeseries",
          "title": "Login outcomes",
          "description": "Logins per second by outcome. Unknown usernames count as `invalid_password`, so this panel cannot be used to enumerate accounts.",
          "datasource": "${DS}",
          "transparent": true,
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 0,
            "y": 18
          },
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "min": 0,
              "custom": {
                "drawStyle": "bars",
                "fillOpacity": 60,
                "showPoints": "never",
                "stacking": {
                  "mode": "normal"
                }
              }
            },
            "overrides": []
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": ["min", "max", "mean", "lastNotNull", "sum"]
            },
            "tooltip": {
              "mode": "multi",
              "sort": "desc"
            }
          },
          "targets": [
            {
              "refId": "Q",
              "datasource": "${DS}",
              "expr": "sum by (result) (increase(as3m_auth_logins_total{job=\"$job\", instance=~\"$instance\"}[$__rate_interval]))",
              "legendFormat": "{{result}}"
            }
          ]
        },
        {
          "id": 20,
          "type": "timeseries",
          "title": "Bans: rate & active",
          "description": "Bans issued per second (a brute-force signal) and how many are currently in force. Admins are exempt from banning by design.",
          "datasource": "${DS}",
          "transparent": true,
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 12,
            "y": 18
          },
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "min": 0,
              "custom": {
                "drawStyle": "line",
                "fillOpacity": 12,
                "showPoints": "never",
                "stacking": {
                  "mode": "none"
                }
              }
            },
            "overrides": []
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": ["min", "max", "mean", "lastNotNull"]
            },
            "tooltip": {
              "mode": "multi",
