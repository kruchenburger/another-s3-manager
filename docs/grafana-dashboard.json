{
  "__note": "Canonical source of truth — edit this file by hand, never by exporting from the Grafana UI (export injects __inputs and concrete datasource UIDs and breaks portability). Portability comes from the ${DS} datasource variable used by every panel.",
  "title": "Another S3 Manager",
  "uid": "as3m-overview",
  "tags": ["another-s3-manager", "s3", "mcp", "self-hosted"],
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "",
  "templating": {
    "list": [
      {
        "name": "DS",
        "label": "Data source",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "job",
        "label": "Job",
        "type": "query",
        "datasource": "${DS}",
        "query": "label_values(as3m_app_info, job)",
        "refresh": 2,
        "sort": 1,
        "current": {},
        "hide": 0
      },
      {
        "name": "instance",
        "label": "Instance",
        "type": "query",
        "datasource": "${DS}",
        "query": "label_values(as3m_app_info{job=\"$job\"}, instance)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "multi": true,
        "current": {},
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate",
      "description": "HTTP requests served per second. The app's overall load; a sustained drop to zero means it stopped receiving traffic (or the scrape target is down).",
      "datasource": "${DS}",
      "transparent": true,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "min": 0 },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS}",
          "expr": "sum(rate(as3m_http_requests_total{job=\"$job\", instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "requests/s"
        }
      ]
    }
  ]
}
