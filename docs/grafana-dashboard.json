{
  "__note": "Canonical source of truth — edit this file by hand, never by exporting from the Grafana UI (export injects __inputs and concrete datasource UIDs and breaks portability). Portability comes from the ${DS} datasource variable used by every panel.",
  "title": "Another S3 Manager",
  "uid": "as3m-overview",
  "tags": ["another-s3-manager", "s3", "mcp", "self-hosted"],
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "",
  "templating": {
    "list": [
      {
        "name": "DS",
        "label": "Data source",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "job",
        "label": "Job",
        "type": "query",
        "datasource": "${DS}",
        "query": "label_values(as3m_app_info, job)",
        "refresh": 2,
        "sort": 1,
        "current": {},
        "hide": 0
      },
      {
        "name": "instance",
        "label": "Instance",
        "type": "query",
        "datasource": "${DS}",
        "query": "label_values(as3m_app_info{job=\"$job\"}, instance)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {},
        "hide": 0
      },
      {
        "name": "role",
        "label": "Role",
        "type": "query",
        "datasource": "${DS}",
        "query": "label_values(as3m_s3_operations_total, role)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {},
        "hide": 0
      },
      {
        "name": "bucket",
        "label": "Bucket",
        "type": "query",
        "datasource": "${DS}",
        "query": "label_values(as3m_s3_objects_total{role=~\"$role\"}, bucket)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {},
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Overview",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Version",
      "description": "The running application version. Changes after a deploy.",
      "datasource": "${DS}",
      "transparent": true,
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "name",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS}",
          "expr": "as3m_app_info{job=\"$job\", instance=~\"$instance\"}",
          "legendFormat": "{{version}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Uptime",
      "description": "Time since the app started; drops to zero on a restart. Linux only.",
      "datasource": "${DS}",
      "transparent": true,
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "B",
          "datasource": "${DS}",
          "expr": "time() - process_start_time_seconds{job=\"$job\", instance=~\"$instance\"}"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "In-flight requests",
      "description": "Requests being handled right now.",
      "datasource": "${DS}",
      "transparent": true,
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "C",
          "datasource": "${DS}",
          "expr": "sum(as3m_http_requests_in_flight{job=\"$job\", instance=~\"$instance\"})"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request rate",
      "description": "HTTP requests per second — overall load.",
      "datasource": "${DS}",
      "transparent": true,
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["min", "max", "mean", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "D",
          "datasource": "${DS}",
          "expr": "sum(rate(as3m_http_requests_total{job=\"$job\", instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "requests/s"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "5xx error rate",
      "description": "Share of requests failing with a server error. Sustained non-zero needs a look.",
      "datasource": "${DS}",
      "transparent": true,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["min", "max", "mean", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "E",
          "datasource": "${DS}",
          "expr": "sum(rate(as3m_http_requests_total{job=\"$job\", instance=~\"$instance\", status_code=~\"5..\"}[$__rate_interval])) / sum(rate(as3m_http_requests_total{job=\"$job\", instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "5xx ratio"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Request latency p95",
      "description": "95% of requests finish faster than this; a rising line means things are slowing down.",
      "datasource": "${DS}",
      "transparent": true,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["min", "max", "mean", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "F",
          "datasource": "${DS}",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(as3m_http_request_duration_seconds_bucket{job=\"$job\", instance=~\"$instance\"}[$__rate_interval])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 8,
      "type": "row",
      "title": "Storage activity",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 15
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Objects added / deleted",
      "description": "Objects uploaded and deleted over time. A folder delete counts every object inside it.",
      "datasource": "${DS}",
      "transparent": true,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["max", "lastNotNull", "sum"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "G",
          "datasource": "${DS}",
          "expr": "round(sum by (bucket, operation) (increase(as3m_s3_objects_total{job=\"$job\", instance=~\"$instance\", role=~\"$role\", bucket=~\"$bucket\"}[$__interval])))",
          "legendFormat": "{{bucket}} · {{operation}}"
        }
      ],
      "interval": "1m"
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Throughput",
      "description": "Bytes uploaded and downloaded per second, by bucket.",
      "datasource": "${DS}",
      "transparent": true,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["min", "max", "mean", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "H",
          "datasource": "${DS}",
          "expr": "sum by (bucket, direction) (rate(as3m_s3_bytes_total{job=\"$job\", instance=~\"$instance\", role=~\"$role\", bucket=~\"$bucket\"}[$__rate_interval]))",
          "legendFormat": "{{bucket}} · {{direction}}"
        }
      ]
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Objects processed (total)",
      "description": "Total objects uploaded, deleted, and copied.",
      "datasource": "${DS}",
      "transparent": true,
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "I",
          "datasource": "${DS}",
          "expr": "sum(as3m_s3_objects_total{job=\"$job\", instance=~\"$instance\", role=~\"$role\", bucket=~\"$bucket\"})",
          "legendFormat": "objects"
        }
      ]
    },
    {
      "id": 12,
      "type": "table",
      "title": "Top buckets by objects processed",
      "description": "Buckets with the most object activity.",
      "datasource": "${DS}",
      "transparent": true,
      "gridPos": {
        "h": 8,
        "w": 18,
        "x": 6,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "refId": "J",
          "datasource": "${DS}",
          "expr": "topk(10, sum by (bucket) (as3m_s3_objects_total{job=\"$job\", instance=~\"$instance\", role=~\"$role\", bucket=~\"$bucket\"}))",
          "legendFormat": "{{bucket}}",
          "instant": true,
          "format": "table"
        }
      ]
    },
    {
      "id": 18,
      "type": "row",
      "title": "S3 health",
      "collapsed": true,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "panels": [
        {
          "id": 13,
          "type": "timeseries",
          "title": "Operations by type",
          "description": "S3 operations over time by type: list, get, put, delete, head.",
          "datasource": "${DS}",
          "transparent": true,
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 0,
            "y": 17
          },
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "min": 0,
              "custom": {
                "drawStyle": "bars",
                "fillOpacity": 60,
                "showPoints": "never",
                "stacking": {
                  "mode": "none"
                }
              }
            },
            "overrides": []
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": ["max", "lastNotNull", "sum"]
            },
            "tooltip": {
              "mode": "multi",
              "sort": "desc"
            }
          },
          "targets": [
            {
              "refId": "K",
              "datasource": "${DS}",
              "expr": "round(sum by (operation) (increase(as3m_s3_operations_total{job=\"$job\", instance=~\"$instance\", role=~\"$role\"}[$__interval])))",
              "legendFormat": "{{operation}}"
            }
          ],
          "interval": "1m"
        },
        {
          "id": 14,
          "type": "timeseries",
          "title": "Errors by cause",
          "description": "Failed S3 operations by cause. access_denied = permissions changed; throttled = S3 is rate-limiting you.",
          "datasource": "${DS}",
          "transparent": true,
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 12,
            "y": 17
          },
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "min": 0,
              "custom": {
                "drawStyle": "bars",
                "fillOpacity": 60,
                "showPoints": "never",
                "stacking": {
                  "mode": "none"
                }
              }
            },
            "overrides": []
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": ["max", "lastNotNull", "sum"]
            },
            "tooltip": {
              "mode": "multi",
              "sort": "desc"
            }
          },
          "targets": [
            {
              "refId": "L",
              "datasource": "${DS}",
              "expr": "round(sum by (error_code) (increase(as3m_s3_operations_total{job=\"$job\", instance=~\"$instance\", role=~\"$role\", error_code!=\"none\"}[$__interval])))",
              "legendFormat": "{{error_code}}"
            }
          ],
          "interval": "1m"
        },
        {
          "id": 15,
          "type": "timeseries",
          "title": "Operation latency p95",
          "description": "95% of S3 operations finish faster than this, by type.",
          "datasource": "${DS}",
          "transparent": true,
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 0,
            "y": 25
          },
          "fieldConfig": {
            "defaults": {
              "unit": "s",
              "min": 0,
              "custom": {
                "drawStyle": "line",
                "fillOpacity": 12,
                "showPoints": "never",
                "stacking": {
                  "mode": "none"
                }
              }
            },
            "overrides": []
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": ["min", "max", "mean", "lastNotNull"]
            },
            "tooltip": {
              "mode": "multi",
              "sort": "desc"
            }
          },
          "targets": [
            {
              "refId": "M",
              "datasource": "${DS}",
              "expr": "histogram_quantile(0.95, sum by (le, operation) (rate(as3m_s3_operation_duration_seconds_bucket{job=\"$job\", instance=~\"$instance\"}[$__rate_interval])))",
              "legendFormat": "{{operation}}"
            }
          ]
        },
        {
          "id": 16,
          "type": "timeseries",
          "title": "Credential-expiry retries",
          "description": "Retries after credentials expired mid-request. A steady rate means the session lifetime is too short.",
          "datasource": "${DS}",
          "transparent": true,
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 12,
            "y": 25
          },
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "min": 0,
              "custom": {
                "drawStyle": "bars",
                "fillOpacity": 60,
                "showPoints": "never",
                "stacking": {
                  "mode": "none"
                }
              }
            },
            "overrides": []
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": ["max", "lastNotNull", "sum"]
            },
            "tooltip": {
              "mode": "multi",
              "sort": "desc"
            }
          },
          "targets": [
            {
              "refId": "N",
              "datasource": "${DS}",
              "expr": "round(sum by (reason) (increase(as3m_s3_retries_total{job=\"$job\", instance=~\"$instance\"}[$__interval])))",
              "legendFormat": "{{reason}}"
            }
          ],
          "interval": "1m"
        },
        {
          "id": 17,
          "type": "timeseries",
          "title": "STS assume-role & refresh failures",
          "description": "Failed role-assume and credential-refresh calls; a spike explains sudden access-denied errors.",
          "datasource": "${DS}",
          "transparent": true,
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 0,
            "y": 33
          },
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "min": 0,
              "custom": {
                "drawStyle": "bars",
                "fillOpacity": 60,
                "showPoints": "never",
                "stacking": {
                  "mode": "none"
                }
              }
            },
            "overrides": []
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": ["max", "lastNotNull", "sum"]
            },
            "tooltip": {
              "mode": "multi",
              "sort": "desc"
            }
          },
          "targets": [
            {
              "refId": "O",
              "datasource": "${DS}",
              "expr": "round(sum(increase(as3m_sts_assume_role_total{job=\"$job\", instance=~\"$instance\", role=~\"$role\", result=\"error\"}[$__interval])))",
              "legendFormat": "assume-role errors"
            },
            {
              "refId": "P",
              "datasource": "${DS}",
              "expr": "round(sum(increase(as3m_credentials_refreshed_total{job=\"$job\", instance=~\"$instance\", role=~\"$role\", result=\"error\"}[$__interval])))",
              "legendFormat": "refresh errors"
            }
          ],
          "interval": "1m"
        }
      ]
    },
    {
      "id": 25,
      "type": "row",
      "title": "Auth & security",
      "collapsed": true,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 33
      },
      "panels": [
        {
          "id": 19,
          "type": "timeseries",
          "title": "Login outcomes",
          "description": "Login attempts by outcome: success, invalid password, or banned.",
          "datasource": "${DS}",
          "transparent": true,
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 0,
            "y": 18
          },
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "min": 0,
              "custom": {
                "drawStyle": "bars",
                "fillOpacity": 60,
                "showPoints": "never",
                "stacking": {
                  "mode": "normal"
                }
              }
            },
            "overrides": []
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": ["max", "lastNotNull", "sum"]
            },
            "tooltip": {
              "mode": "multi",
              "sort": "desc"
            }
          },
          "targets": [
            {
              "refId": "Q",
              "datasource": "${DS}",
              "expr": "round(sum by (result) (increase(as3m_auth_logins_total{job=\"$job\", instance=~\"$instance\"}[$__interval])))",
              "legendFormat": "{{result}}"
            }
          ],
          "interval": "1m"
        },
        {
          "id": 20,
          "type": "timeseries",
          "title": "Bans issued",
          "description": "Bans issued after repeated failed logins — a brute-force signal. Admins are exempt.",
          "datasource": "${DS}",
          "transparent": true,
          "gridPos": {
            "h": 8,
            "w": 8,
            "x": 12,
            "y": 18
          },
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "min": 0,
              "custom": {
                "drawStyle": "bars",
                "fillOpacity": 60,
                "showPoints": "never",
                "stacking": {
                  "mode": "none"
                }
              }
            },
            "overrides": []
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": ["max", "lastNotNull", "sum"]
            },
            "tooltip": {
              "mode": "multi",
              "sort": "desc"
            }
          },
          "targets": [
            {
              "refId": "R",
              "datasource": "${DS}",
              "expr": "round(sum(increase(as3m_auth_bans_total{job=\"$job\", instance=~\"$instance\"}[$__interval])))",
              "legendFormat": "bans"
            }
